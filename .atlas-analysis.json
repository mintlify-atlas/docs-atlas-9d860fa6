  "keyFeatures": [
    "Real-time monitoring dashboards with live data updates",
    "Interactive maps with geo-located sensors and infrastructure",
    "Multiple chart types for data visualization (gauges, liquid fill, pie, bar, line)",
    "Visual diagram editor for network schemas using Konva",
    "Alarm and notification system with configurable triggers",
    "PLC profile configuration and variable management",
    "Pump control and monitoring with status indicators",
    "User authentication and role-based access control",
    "Desktop application with Tauri for native performance",
    "Data export capabilities (CSV, PDF reports)"
  ],
  "publicApiSurface": [
    "/login - User authentication",
    "/dashboardCharts - Fetch dashboard chart configurations",
    "/indicatorCharts - Retrieve indicator charts for home view",
    "/multipleDataInflux - Batch fetch real-time data from InfluxDB",
    "/map - Create, read, update map configurations",
    "/diagram - Manage network diagrams",
    "/vars - Configure InfluxDB variables",
    "/plc - Configure PLC profiles",
    "/alarm - Alarm configuration endpoints",
    "/notifications - Notification settings",
    "/security - User security and permissions",
    "/pumps - Pump monitoring and control data"
  ]
